# Control panel — LAN remote for the Pi dashboards.

PORT=8080
# Bind address. Defaults to 0.0.0.0 ON PURPOSE: this panel is meant to be reached
# from your phone across the LAN (unlike the dashboards, which stay loopback-only).
HOST=0.0.0.0

# Optional shared PIN. Leave blank for an open panel (anyone on your wifi can
# switch displays / reboot / shut down). Set it to require the PIN for those
# actions (sent by the UI as an x-control-pin header). Reading status stays open.
# CONTROL_PIN=

# Override the repo root if the clone isn't two levels up from apps/control.
# REPO_ROOT=
