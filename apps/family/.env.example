PORT=3001
NODE_ENV=development

# Network bind address. Defaults to 127.0.0.1 (loopback) — the kiosk only needs
# localhost, and a family calendar is private. Set to 0.0.0.0 to view from other
# devices; if you do, set REFRESH_TOKEN below.
# HOST=127.0.0.1

# Optional token guarding POST /api/refresh (X-Refresh-Token header or ?token=).
# REFRESH_TOKEN=

# Display timezone for the whole board.
TIMEZONE=America/Los_Angeles

# Data source: manual | ical
#   manual - hand-edited data/manual/events.json (default, no network)
#   ical   - live fetch of Google calendars via their secret iCal URLs
CAL_PROVIDER=manual

# For CAL_PROVIDER=ical: a JSON array of calendars to merge. Get each URL from
# Google Calendar -> Settings -> the calendar -> "Secret address in iCal format".
# Keep this secret (it grants read access) — that's why it lives in .env, not git.
# ICAL_SOURCES=[{"id":"family","label":"Family","color":"#2dd4bf","url":"https://calendar.google.com/calendar/ical/XXX/private-YYY/basic.ics"},{"id":"school","label":"School","color":"#f59e0b","url":"https://calendar.google.com/calendar/ical/ZZZ/private-WWW/basic.ics"}]
