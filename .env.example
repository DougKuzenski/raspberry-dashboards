PORT=3000
NODE_ENV=development

# Network bind address. Defaults to 127.0.0.1 (loopback) — the kiosk only needs
# localhost, so the server isn't exposed to the LAN. Set to 0.0.0.0 to view the
# dashboard from other devices; if you do, set REFRESH_TOKEN below.
# HOST=127.0.0.1

# Optional token guarding POST /api/refresh. When set, callers must send it as an
# `X-Refresh-Token` header or `?token=` query param. Leave blank to keep refresh
# open (fine when bound to loopback).
# REFRESH_TOKEN=

# Data source: manual | openfootball | football_data | worldcup_api
#   manual       - hand-edited data/manual/*.json (default, no network)
#   openfootball - live fetch of OpenFootball worldcup.json — fixtures only, no key
#   football_data- live scores + status from football-data.org (needs a free key below)
#   worldcup_api - local sample-remote stub (demo of the normalize pipeline)
DATA_PROVIDER=manual

ENABLE_MANUAL_OVERRIDES=true
TIMEZONE=America/Los_Angeles

# Override the OpenFootball source URL if desired (defaults to the 2026 file on
# raw.githubusercontent.com). Leave blank to use the built-in default.
EXTERNAL_API_BASE_URL=
EXTERNAL_API_KEY=

# football-data.org live provider (free key: https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=
# FOOTBALL_DATA_BASE_URL=https://api.football-data.org   # override only if needed
