PORT=3000
NODE_ENV=development

# Data source: manual | openfootball | worldcup_api
#   manual      - hand-edited data/manual/*.json (default, no network)
#   openfootball- live fetch of OpenFootball public-domain worldcup.json (no key)
#   worldcup_api- local sample-remote stub (demo of the normalize pipeline)
DATA_PROVIDER=manual

ENABLE_MANUAL_OVERRIDES=true
TIMEZONE=America/Los_Angeles

# Override the OpenFootball source URL if desired (defaults to the 2026 file on
# raw.githubusercontent.com). Leave blank to use the built-in default.
EXTERNAL_API_BASE_URL=
EXTERNAL_API_KEY=
